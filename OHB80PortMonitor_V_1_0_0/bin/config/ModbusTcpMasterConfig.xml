<?xml version="1.0" encoding="UTF-8"?>
<ModbusTcpMasterConfig version="1.0">

    <!-- ==================== 初始化指令集 ==================== -->
    <InitialCommands>
        <CommandInterval>100</CommandInterval>
        <CommandTimeout>1000</CommandTimeout>
        <RetryCount>3</RetryCount>
        <CommandSet>
            <Command ref="ReadVersion"/>
        </CommandSet>
    </InitialCommands>

    <!-- ==================== 周期轮询指令集 ==================== -->
    <PeriodicCommands>
        <CommandInterval>1000</CommandInterval>
        <CommandTimeout>1000</CommandTimeout>
        <RetryCount>0</RetryCount>
        <CommandSet>
            <Command ref="ReadGeneralStatus"/>
        </CommandSet>
    </PeriodicCommands>

    <!-- ==================== 业务指令集 ==================== -->
    <BusinessCommands>
        <CommandTimeout>1000</CommandTimeout>
        <RetryCount>5</RetryCount>
    </BusinessCommands>

    <!-- ==================== 指令定义 ==================== -->
    <CommandDefinitions>

        <!-- ========================================
             1. 功能码 01 — 读线圈
             读取电磁阀状态，4个线圈
             请求帧: 01 01 00 00 00 04
             响应帧: 01 01 01 XX
             ======================================== -->
        <Command id="ReadCoilStatus">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>01</Function>
                <StartAddr>00 00</StartAddr>
                <RegisterCount>00 04</RegisterCount>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>01</Function>
                <ByteCount>01</ByteCount>
                <RegisterValue>00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             2. 功能码 04 — 读输入寄存器（多寄存器）
             读取 FOUP 状态，9个输入寄存器
             请求帧: 01 04 00 00 00 09
             响应帧: 01 04 12 XX×18
             ======================================== -->
        <Command id="ReadFoupStatus">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <StartAddr>00 00</StartAddr>
                <RegisterCount>00 09</RegisterCount>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <ByteCount>12</ByteCount>
                <RegisterValue>00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             4. 功能码 04 — 读输入寄存器（单寄存器）
             读取固件版本号
             请求帧: 01 04 00 18 00 01
             响应帧: 01 04 02 XX XX
             ======================================== -->
        <Command id="ReadVersion">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <StartAddr>00 18</StartAddr>
                <RegisterCount>00 01</RegisterCount>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <ByteCount>02</ByteCount>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             示例: 功能码 0F — 写多个线圈
             写入5个线圈，13h = 00010011b
             线圈1=ON, 线圈2=ON, 线圈3=OFF, 线圈4=OFF, 线圈5=ON
             请求帧: 01 0F 00 12 00 05 01 13
             响应帧: 01 0F 00 12 00 05
             ======================================== -->
        <Command id="WriteMultipleCoilsExample">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>0F</Function>
                <StartAddr>00 12</StartAddr>
                <CoilCount>00 05</CoilCount>
                <ByteCount>01</ByteCount>
                <CoilValue>13</CoilValue>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>0F</Function>
                <StartAddr>00 12</StartAddr>
                <CoilCount>00 05</CoilCount>
            </respond>
        </Command>

        <!-- ========================================
             示例: 功能码 10 — 写多个保持寄存器
             写入2个寄存器：0x0013=19, 0x0011=17
             请求帧: 01 10 00 12 00 02 04 00 13 00 11
             响应帧: 01 10 00 12 00 02
             ======================================== -->
        <Command id="WriteMultipleRegistersExample">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>10</Function>
                <StartAddr>00 12</StartAddr>
                <RegisterCount>00 02</RegisterCount>
                <ByteCount>04</ByteCount>
                <RegisterValues>00 13 00 11</RegisterValues>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>10</Function>
                <StartAddr>00 12</StartAddr>
                <RegisterCount>00 02</RegisterCount>
            </respond>
        </Command>

        <!-- ========================================
             5. 功能码 04 — 读输入寄存器（多寄存器）
             读取通用状态，9个输入寄存器
             请求帧: 01 04 00 00 00 09 30 0c
             响应帧: 01 04 12 XX×18
             ======================================== -->
        <Command id="ReadGeneralStatus">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <StartAddr>00 00</StartAddr>
                <RegisterCount>00 09</RegisterCount>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <ByteCount>12</ByteCount>
                <RegisterValue>00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             6. 功能码 04 — 读输入寄存器（单寄存器）
             查询 idle purge 使能
             请求帧: 01 04 00 1D 00 01 A1 CC
             响应帧: 01 04 02 XX XX
             ======================================== -->
        <Command id="ReadIdlePurgeEnable">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <StartAddr>00 1D</StartAddr>
                <RegisterCount>00 01</RegisterCount>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <ByteCount>02</ByteCount>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             7. 功能码 04 — 读输入寄存器（单寄存器）
             查询 idle purge 状态
             请求帧: 01 04 00 1E 00 01 51 CC
             响应帧: 01 04 02 XX XX
             ======================================== -->
        <Command id="ReadIdlePurgeStatus">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <StartAddr>00 1E</StartAddr>
                <RegisterCount>00 01</RegisterCount>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <ByteCount>02</ByteCount>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             8. 功能码 04 — 读输入寄存器（单寄存器）
             idle purge 时间查询
             请求帧: 01 04 00 1F 00 01 00 0C
             响应帧: 01 04 02 XX XX
             ======================================== -->
        <Command id="ReadIdlePurgeTime">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <StartAddr>00 1F</StartAddr>
                <RegisterCount>00 01</RegisterCount>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <ByteCount>02</ByteCount>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             9. 功能码 06 — 写单个保持寄存器
             写入 idle purge 使能（1=开启，0=关闭）
             请求帧: 01 06 00 14 XX XX
             响应帧: 01 06 00 14 XX XX（镜像）
             ======================================== -->
        <Command id="WriteIdlePurgeEnable">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>06</Function>
                <StartAddr>00 14</StartAddr>
                <!-- 写入值，固定2字节：1=开启，0=关闭 -->
                <RegisterValue>00 00</RegisterValue>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>06</Function>
                <StartAddr>00 14</StartAddr>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             10. 功能码 06 — 写单个保持寄存器
             写入 idle purge 充气时间（秒）
             请求帧: 01 06 00 15 XX XX
             响应帧: 01 06 00 15 XX XX（镜像）
             ======================================== -->
        <Command id="WriteIdlePurgeTime">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>06</Function>
                <StartAddr>00 15</StartAddr>
                <!-- 写入值，固定2字节：计时时长（s） -->
                <RegisterValue>00 00</RegisterValue>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>06</Function>
                <StartAddr>00 15</StartAddr>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             11. 功能码 06 — 写单个保持寄存器
             写入 idle purge 充气间隔（秒）
             请求帧: 01 06 00 16 XX XX
             响应帧: 01 06 00 16 XX XX（镜像）
             ======================================== -->
        <Command id="WriteIdlePurgeInterval">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>06</Function>
                <StartAddr>00 16</StartAddr>
                <!-- 写入值，固定2字节：计时时长（s） -->
                <RegisterValue>00 00</RegisterValue>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>06</Function>
                <StartAddr>00 16</StartAddr>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

    </CommandDefinitions>

</ModbusTcpMasterConfig>
