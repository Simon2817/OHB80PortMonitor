<?xml version="1.0" encoding="UTF-8"?>
<ModbusTcpMasterConfig version="1.0">

    <!-- ==================== 初始化指令集 ==================== -->
    <InitialCommands>
        <CommandInterval>100</CommandInterval>
        <CommandTimeout>1000</CommandTimeout>
        <RetryCount>3</RetryCount>
        <CommandSet>
            <Command ref="ReadVersion"/>
        </CommandSet>
    </InitialCommands>

    <!-- ==================== 周期轮询指令集 ==================== -->
    <PeriodicCommands>
        <CommandInterval>1000</CommandInterval>
        <CommandTimeout>1000</CommandTimeout>
        <RetryCount>0</RetryCount>
        <CommandSet>
            <Command ref="ReadFoupStatus"/>
        </CommandSet>
    </PeriodicCommands>

    <!-- ==================== 业务指令集 ==================== -->
    <BusinessCommands>
        <CommandTimeout>1000</CommandTimeout>
        <RetryCount>5</RetryCount>
    </BusinessCommands>

    <!-- ==================== 指令定义 ==================== -->
    <CommandDefinitions>

        <!-- ========================================
             2. 功能码 04 — 读输入寄存器（多寄存器）
             FOUP 属性查询指令
             读取 FOUP 属性：进气压力、负压、流量、湿度、温度、FOUP IN 充气时间等
             请求帧: 01 04 00 00 00 09
             响应帧: 01 04 12 XX×18
             
             CH_1: 进气主路气压值 (0~10Bar)     = (256*hi + lo) / 10000
             CH_2: 负压值                        = (256*hi + lo) / 10000
             CH_3: 进气主路流量值 (4~200L/Min)  = (256*hi + lo) / 100
             CH_4: 真空回路相对湿度 (0~100%)    = (256*hi + lo) / 100
             CH_5: 真空回路气体温度 (0~100℃)   = (256*hi + lo) / 100
             CH_6: 预留
             CH_7: FOUP IN 充气秒数 (高16位)    = (256*hi + lo)
             CH_8: FOUP IN 充气秒数 (低16位)    = (256*hi + lo)
             CH_9: 预留
             ======================================== -->
        <Command id="ReadFoupStatus">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <StartAddr>00 00</StartAddr>
                <RegisterCount>00 09</RegisterCount>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <ByteCount>12</ByteCount>
                <RegisterValue>00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00</RegisterValue>
            </respond>
        </Command>
        
        <!-- ========================================
             6. 功能码 04 — 读输入寄存器（单寄存器）
             查询 idle purge 使能
             请求帧: 01 04 00 1D 00 01 A1 CC
             响应帧: 01 04 02 XX XX
             ======================================== -->
        <Command id="ReadIdlePurgeEnable">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <StartAddr>00 1D</StartAddr>
                <RegisterCount>00 01</RegisterCount>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <ByteCount>02</ByteCount>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             7. 功能码 04 — 读输入寄存器（单寄存器）
             查询 idle purge 状态
             请求帧: 01 04 00 1E 00 01 51 CC
             响应帧: 01 04 02 XX XX
             ======================================== -->
        <Command id="ReadIdlePurgeStatus">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <StartAddr>00 1E</StartAddr>
                <RegisterCount>00 01</RegisterCount>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <ByteCount>02</ByteCount>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             8. 功能码 04 — 读输入寄存器（单寄存器）
             idle purge 工作计时时间查询
             请求帧: 01 04 00 1F 00 01 00 0C
             响应帧: 01 04 02 XX XX
             ======================================== -->
        <Command id="ReadIdlePurgeWorkingTime">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <StartAddr>00 1F</StartAddr>
                <RegisterCount>00 01</RegisterCount>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>04</Function>
                <ByteCount>02</ByteCount>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             9. 功能码 06 — 写单个保持寄存器
             写入 idle purge 使能（1=开启，0=关闭）
             请求帧: 01 06 00 14 XX XX
             响应帧: 01 06 00 14 XX XX（镜像）
             ======================================== -->
        <Command id="WriteIdlePurgeEnable">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>06</Function>
                <StartAddr>00 14</StartAddr>
                <!-- 写入值，固定2字节：1=开启，0=关闭 -->
                <RegisterValue>00 00</RegisterValue>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>06</Function>
                <StartAddr>00 14</StartAddr>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             10. 功能码 06 — 写单个保持寄存器
             写入 idle purge 充气时间（秒）
             请求帧: 01 06 00 15 XX XX
             响应帧: 01 06 00 15 XX XX（镜像）
             ======================================== -->
        <Command id="WriteIdlePurgeTime">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>06</Function>
                <StartAddr>00 15</StartAddr>
                <!-- 写入值，固定2字节：计时时长（s） -->
                <RegisterValue>00 00</RegisterValue>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>06</Function>
                <StartAddr>00 15</StartAddr>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

        <!-- ========================================
             11. 功能码 06 — 写单个保持寄存器
             写入 idle purge 充气间隔（秒）
             请求帧: 01 06 00 16 XX XX
             响应帧: 01 06 00 16 XX XX（镜像）
             ======================================== -->
        <Command id="WriteIdlePurgeInterval">
            <request>
                <SlaveAddr>01</SlaveAddr>
                <Function>06</Function>
                <StartAddr>00 16</StartAddr>
                <!-- 写入值，固定2字节：计时时长（s） -->
                <RegisterValue>00 00</RegisterValue>
            </request>
            <respond>
                <SlaveAddr>01</SlaveAddr>
                <Function>06</Function>
                <StartAddr>00 16</StartAddr>
                <RegisterValue>00 00</RegisterValue>
            </respond>
        </Command>

    </CommandDefinitions>

</ModbusTcpMasterConfig>
