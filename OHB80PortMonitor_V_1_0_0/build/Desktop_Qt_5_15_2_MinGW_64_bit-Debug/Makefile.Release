####### Build rules

first: all
all: Makefile.Release  ../../bin/x64/OHB80PortMonitor_V_1_0_0.exe

../../bin/x64/OHB80PortMonitor_V_1_0_0.exe: C:/Qt/5.15.2/mingw81_64/lib/libQt5PrintSupport.a C:/Qt/5.15.2/mingw81_64/lib/libQt5Widgets.a C:/Qt/5.15.2/mingw81_64/lib/libQt5Gui.a C:/Qt/5.15.2/mingw81_64/lib/libQt5Concurrent.a C:/Qt/5.15.2/mingw81_64/lib/libQt5SerialPort.a C:/Qt/5.15.2/mingw81_64/lib/libQt5SerialBus.a C:/Qt/5.15.2/mingw81_64/lib/libQt5Network.a C:/Qt/5.15.2/mingw81_64/lib/libQt5Xml.a C:/Qt/5.15.2/mingw81_64/lib/libQt5Core.a C:/Qt/5.15.2/mingw81_64/lib/libqtmain.a ui_alarmpage.h ui_chartpage.h ui_communicatepage.h ui_configpage.h ui_debugpage.h ui_homepage.h ui_uidemo6.h ui_framedevice.h ui_firmwareupdatewidget.h ui_loggerwidget.h ui_alarmloggerwidget.h ui_historycalendardialog.h ui_communicateloggerwidget.h $(OBJECTS) release/OHB80PortMonitor_V_1_0_0_resource_res.o
