release/OHB80PortMonitor_V_1_0_0_resource_res.o: OHB80PortMonitor_V_1_0_0_resource.rc
	windres -i OHB80PortMonitor_V_1_0_0_resource.rc -o release\OHB80PortMonitor_V_1_0_0_resource_res.o --include-dir=. $(DEFINES)

qmake: FORCE
	@$(QMAKE) -o Makefile.Release ..\..\OHB80PortMonitor_V_1_0_0.pro -spec win32-g++ "CONFIG+=debug" "CONFIG+=qml_debug"

qmake_all: FORCE

